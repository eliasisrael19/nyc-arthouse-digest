<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>NYC Arthouse Digest</title>
  </head>
  <body style="margin:0; padding:0; background:#f6f4ef; color:#171717; font-family: Georgia, 'Times New Roman', serif;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f6f4ef;">
      <tr>
        <td align="center" style="padding:24px 12px;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width:760px; background:#fffdf8; border:1px solid #dfd9cc;">
            <tr>
              <td style="padding:22px 22px 14px 22px; border-bottom:3px solid #171717;">
                <div style="font-family: 'Arial Black', Arial, sans-serif; font-size:11px; letter-spacing:1.2px; text-transform:uppercase; color:#5e5545;">
                  Weekly Arthouse Briefing
                </div>
                <div style="font-family: 'Arial Black', Arial, sans-serif; font-size:32px; line-height:1.06; margin-top:6px; color:#111;">
                  NYC Arthouse Digest
                </div>
                <div style="margin-top:10px; font-family: Arial, Helvetica, sans-serif; font-size:13px; color:#4e463b;">
                  <strong>Week:</strong> {{ week_label }}<br />
                  <strong>Generated:</strong> {{ generated_at.strftime('%Y-%m-%d %H:%M') }}
                </div>
              </td>
            </tr>

            <tr>
              <td style="padding:18px 22px 8px 22px;">
                <div style="font-family: Arial, Helvetica, sans-serif; font-size:18px; font-weight:700; letter-spacing:0.2px; color:#111; margin-bottom:10px;">
                  Top Picks
                </div>

                {% if top_picks %}
                  {% for item in top_picks %}
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 10px 0; border:1px solid #ddd4c4; background:#fff;">
                    <tr>
                      <td style="padding:11px 12px;">
                        <div style="font-family: Arial, Helvetica, sans-serif; font-size:16px; line-height:1.25; font-weight:700; margin:0 0 4px 0;">
                          <a href="{{ item.url }}" style="color:#111; text-decoration:none;">{{ item.title }}</a>
                        </div>
                        <div style="font-family: Arial, Helvetica, sans-serif; font-size:12px; color:#5f5649; text-transform:uppercase; letter-spacing:0.4px; margin-bottom:3px;">
                          {{ item.venue }}{% if item.start %} • {{ item.start.strftime('%a %b %d, %I:%M %p') }}{% endif %}
                        </div>
                        {% if item.notes %}
                        <div style="font-family: Arial, Helvetica, sans-serif; font-size:13px; color:#2d2922; line-height:1.35;">
                          {{ item.notes }}
                        </div>
                        {% endif %}
                        {% set pick_reason = top_pick_reasons.get(item.normalized_title) %}
                        {% if pick_reason %}
                        <div style="font-family: Arial, Helvetica, sans-serif; font-size:13px; color:#23394a; margin-top:6px; line-height:1.45;">
                          <strong>Why this is a top pick:</strong> {{ pick_reason }}
                        </div>
                        {% endif %}
                        {% set venues = cross_venue.get(item.normalized_title, []) %}
                        {% if venues|length > 1 %}
                        <div style="font-family: Arial, Helvetica, sans-serif; font-size:12px; color:#7a6f5e; margin-top:4px;">
                          Also playing at {{ venues|length - 1 }} other NYC venue(s)
                        </div>
                        {% endif %}
                      </td>
                    </tr>
                  </table>
                  {% endfor %}
                {% else %}
                  <div style="font-family: Arial, Helvetica, sans-serif; font-size:13px; color:#4b4438;">
                    No picks found this week. Check <code>data/manual_highlights.yaml</code>.
                  </div>
                {% endif %}
              </td>
            </tr>

            <tr>
              <td style="padding:6px 22px 20px 22px;">
                <div style="font-family: Arial, Helvetica, sans-serif; font-size:18px; font-weight:700; letter-spacing:0.2px; color:#111; margin-bottom:10px;">
                  Venue Guide
                </div>
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:20px; border:1px solid #ddd4c4; background:#fff;">
                  <tr>
                    <td style="padding:10px 12px;">
                      {% for venue, items in by_venue.items() %}
                      <div style="padding:10px 0; border-bottom:{% if loop.last %}0{% else %}1px solid #f0eadf{% endif %}; font-family: Arial, Helvetica, sans-serif; font-size:22px; line-height:1.25; color:#2d2922;">
                        <span style="display:inline-block; min-width:26px; text-align:center; background:#efe8da; border:1px solid #d8ccb6; border-radius:14px; font-size:16px; padding:2px 10px; margin-right:10px; vertical-align:middle;">
                          {{ loop.index }}
                        </span>
                        <strong>{{ venue }}</strong>
                        <span style="color:#6a5f4f; font-size:18px;">({{ items|length }} titles)</span>
                      </div>
                      {% endfor %}
                    </td>
                  </tr>
                </table>

                <div style="font-family: Arial, Helvetica, sans-serif; font-size:18px; font-weight:700; letter-spacing:0.2px; color:#111; margin-bottom:10px;">
                  Listings by Venue
                </div>

                {% for venue, items in by_venue.items() %}
                {% if loop.index0 % 5 == 0 %}
                  {% set venue_header_bg = "#294a5f" %}
                  {% set venue_header_border = "#1b3443" %}
                  {% set venue_box_bg = "#f6f9fb" %}
                {% elif loop.index0 % 5 == 1 %}
                  {% set venue_header_bg = "#5b3f2f" %}
                  {% set venue_header_border = "#402b1f" %}
                  {% set venue_box_bg = "#fbf8f5" %}
                {% elif loop.index0 % 5 == 2 %}
                  {% set venue_header_bg = "#2f5d44" %}
                  {% set venue_header_border = "#1f3f2d" %}
                  {% set venue_box_bg = "#f6faf7" %}
                {% elif loop.index0 % 5 == 3 %}
                  {% set venue_header_bg = "#5c2f4d" %}
                  {% set venue_header_border = "#3f2034" %}
                  {% set venue_box_bg = "#fbf6f9" %}
                {% else %}
                  {% set venue_header_bg = "#3d475e" %}
                  {% set venue_header_border = "#2a3346" %}
                  {% set venue_box_bg = "#f7f8fb" %}
                {% endif %}

                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:20px; border:2px solid {{ venue_header_border }}; background:{{ venue_box_bg }};">
                  <tr>
                    <td style="padding:12px 14px; background:{{ venue_header_bg }}; border-bottom:2px solid {{ venue_header_border }}; font-family: Arial, Helvetica, sans-serif; font-size:18px; font-weight:800; text-transform:uppercase; letter-spacing:0.4px; color:#ffffff;">
                      <span style="display:inline-block; min-width:24px; text-align:center; border:1px solid rgba(255,255,255,0.8); border-radius:12px; font-size:12px; padding:2px 8px; margin-right:8px;">{{ loop.index }}</span>
                      {{ venue }}
                      <span style="font-size:13px; font-weight:600; opacity:0.9; margin-left:8px;">{{ items|length }} titles</span>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding:12px 16px;">
                      {% for item in items %}
                      <div style="padding:14px 0 16px 0; border-bottom:{% if loop.last %}0{% else %}1px solid #e0d9cc{% endif %};">
                        <div style="font-family: Arial, Helvetica, sans-serif; font-size:24px; line-height:1.2; font-weight:800; color:#131313;">
                          <a href="{{ item.url }}" style="color:#111; text-decoration:none;">{{ item.title }}</a>
                        </div>
                        {% if item.summary %}
                        <div style="font-family: Arial, Helvetica, sans-serif; font-size:15px; color:#2d2922; margin-top:8px; line-height:1.65; text-transform:none; letter-spacing:0;">
                          {{ item.summary }}
                        </div>
                        {% endif %}
                        {% for schedule in item.schedule_lines %}
                        <div style="font-family: Arial, Helvetica, sans-serif; font-size:14px; color:#4e463b; text-transform:uppercase; letter-spacing:0.4px; margin-top:9px; line-height:1.5;">
                          {{ schedule }}
                        </div>
                        {% endfor %}
                      </div>
                      {% endfor %}
                    </td>
                  </tr>
                </table>
                {% endfor %}
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
